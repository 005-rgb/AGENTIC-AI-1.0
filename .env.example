# ── Core ──────────────────────────────────────────────
SESSION_SECRET=ganti-dengan-string-random-panjang-minimal-32-karakter

# ── Database ───────────────────────────────────────────
# SQLite (default, cocok untuk dev dan Laragon)
DATABASE_URL=sqlite:///./shortsdb.sqlite

# MySQL (untuk cPanel production)
# DATABASE_URL=mysql+pymysql://username:password@localhost/nama_database

# ── YouTube OAuth ──────────────────────────────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:8000/api/channels/oauth-callback

# ── Telegram Bot (Phase 4) ─────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── WhatsApp via Twilio (Phase 4) ─────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── TikTok Upload API (Phase 3) ────────────────────────
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ── Meta (Instagram/Facebook Reels) (Phase 3) ─────────
META_APP_ID=
META_APP_SECRET=

# ── FFmpeg path (jika tidak di PATH) ──────────────────
# FFMPEG_PATH=/usr/bin/ffmpeg
# FFPROBE_PATH=/usr/bin/ffprobe
